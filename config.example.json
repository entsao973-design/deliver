{
  "excel_path": "",
  "storage_backend": "sqlserver",
  "database": {
    "type": "sqlserver",
    "server": "192.168.0.5",
    "database": "DeliveryPhotoArchive",
    "username": "YOUR_SQL_LOGIN",
    "password": "YOUR_SQL_PASSWORD",
    "driver": "ODBC Driver 17 for SQL Server",
    "encrypt": true,
    "trust_server_certificate": true,
    "create_database": true,
    "initialize_schema": true,
    "timeout": 5
  },
  "data_file": "data\\deliveries.json",
  "user_file": "data\\users.json",
  "upload_dir": "data\\uploads",
  "archive_root": "data\\archives",
  "photo_root": "storage\\photos",
  "geocoding": {
    "enabled": false,
    "provider": "google",
    "api_key_env": "GOOGLE_GEOCODING_API_KEY",
    "country_hint": "Taiwan",
    "country_code": "TW",
    "timeout_seconds": 5
  },
  "scan_ocr": {
    "enabled": false,
    "provider": "google_vision",
    "credentials_file_env": "GOOGLE_APPLICATION_CREDENTIALS",
    "feature_type": "TEXT_DETECTION",
    "timeout_seconds": 10
  },
  "host": "0.0.0.0",
  "port": 8000,
  "users": [
    {
      "username": "driver",
      "password": "1234",
      "role": "driver"
    },
    {
      "username": "admin",
      "password": "admin123",
      "role": "admin"
    }
  ]
}
